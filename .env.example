# Safe local defaults. Do not commit real credentials.
APP_MODE=mock
API_HOST=127.0.0.1
API_PORT=8000
VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_DEMO_MODE=false
CORS_ALLOW_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Controlled live voice remains disabled unless every value is supplied externally.
LIVE_CALLS_ENABLED=false
ELEVENLABS_API_KEY=
ELEVENLABS_INTAKE_AGENT_ID=
ELEVENLABS_OUTBOUND_AGENT_ID=
ELEVENLABS_PHONE_NUMBER_ID=
ELEVENLABS_WEBHOOK_SECRET=
ELEVENLABS_PRECALL_SECRET=
ELEVENLABS_API_BASE_URL=https://api.elevenlabs.io
LIVE_TEST_TO_NUMBERS=
PUBLIC_API_BASE_URL=
RECORDING_SIGNING_SECRET=
VOICE_OPERATOR_SECRET=
AGENT_CONFIG_VERSION=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Optional OpenAI extraction and grounded narration remain independently disabled.
OPENAI_ENABLED=false
OPENAI_API_KEY=
OPENAI_DOCUMENT_MODEL=gpt-5.6-luna
OPENAI_RECOMMENDATION_MODEL=gpt-5.6-terra
OPENAI_API_BASE_URL=https://api.openai.com

# Optional Tavily discovery remains independently disabled.
TAVILY_ENABLED=false
TAVILY_API_KEY=
TAVILY_API_BASE_URL=https://api.tavily.com

# Optional Supabase persistence remains independently disabled.
SUPABASE_ENABLED=false
SUPABASE_URL=
SUPABASE_SECRET_KEY=
# Legacy server-key fallback only. Prefer SUPABASE_SECRET_KEY.
SUPABASE_SERVICE_ROLE_KEY=
